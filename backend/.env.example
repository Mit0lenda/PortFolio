SUPABASE_SERVICE_KEY=your-service-role-key-here

# n8n webhook (non-blocking notification trigger)
N8N_CONTACT_WEBHOOK_URL=https://n8n-n8n.qzqlae.easypanel.host/webhook/portfolio-lead
