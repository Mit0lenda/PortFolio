# Server
PORT=4000
NODE_ENV=production

# CORS — comma-separated allowed origins
CORS_ORIGIN=https://mitolenda.dev,http://localhost:3000

# Supabase (project: aplicativos — id: ttzvattidtrqiujepohy)
SUPABASE_URL=https://ttzvattidtrqiujepohy.supabase.co
