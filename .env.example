# ─── Supabase ─────────────────────────────────────────────────────────────────
# IMPORTANT: Use a DEDICATED Supabase project for the portfolio.
# Do NOT reuse the nexus (construction management) project.
#
# Setup in the dedicated project:
#   CREATE SCHEMA portfolio;
#   CREATE TABLE portfolio.leads ( ... );  -- see migration in docs/supabase-setup.sql
#
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PORTFOLIO_PROJECT_ID.supabase.co

# Anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ─── OpenAI — Lead Classification (server-side only, NEVER expose in client) ──
# Used by classifyLead.ts to auto-classify contact form submissions.
# Model: gpt-4o-mini (fast, cheap). Falls back to manual review if not set.
OPENAI_API_KEY=sk-...

# ─── n8n Integration ──────────────────────────────────────────────────────────
# Webhook URL for the "Portfolio — Novo Lead 📬" workflow
# Found in n8n → Workflow → Webhook node → Copy URL
# Format: https://your-n8n.example.com/webhook/portfolio-lead
N8N_CONTACT_WEBHOOK_URL=https://n8n-n8n.qzqlae.easypanel.host/webhook/portfolio-lead

# ─── Cloudflare Web Analytics ─────────────────────────────────────────────────
# Token from Cloudflare → Analytics → Web Analytics → Add a site
# Leave empty to disable analytics
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ─── Facebook Pixel ───────────────────────────────────────────────────────────
# Pixel ID from Meta Events Manager → Data Sources → your Pixel
# Leave empty to disable (pageview + CTA click tracking via trackCtaClick)
NEXT_PUBLIC_FB_PIXEL_ID=

# ─── Google Search Console ────────────────────────────────────────────────────
# Verification code from Google Search Console → Add property → HTML tag method
# Copy only the value inside content="...", e.g.: abc123XYZ
# Leave empty until you have the code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Bundle Analyzer ──────────────────────────────────────────────────────────
# Set to "true" before running `npm run build` to open the bundle report
# ANALYZE=true npm run build
ANALYZE=false
